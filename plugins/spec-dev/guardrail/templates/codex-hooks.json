{
  "description": "spec-dev 漂移守卫 —— Codex 项目级 hooks（.codex/hooks.json）。PreToolUse 退出码 2 = 阻断本次工具调用并把 stderr 作为反馈回灌给模型。守卫脚本位于 scripts/spec-dev/check-spec-drift.mjs。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/spec-dev/check-spec-drift.mjs --hook",
            "timeout": 15,
            "statusMessage": "spec-dev 漂移守卫检查中"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/spec-dev/session-context.mjs",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
