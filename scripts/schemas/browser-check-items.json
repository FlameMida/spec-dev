{
  "type": "object",
  "required": ["items", "coverage_note"],
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check", "ops", "result", "evidence_ref", "notes"],
        "properties": {
          "check": { "type": "string" },
          "ops": { "type": "string" },
          "result": { "type": "string", "enum": ["pass", "warn", "fail", "unverified"] },
          "evidence_ref": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "coverage_note": { "type": "string" }
  }
}
