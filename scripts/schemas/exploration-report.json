{
  "type": "object",
  "required": ["keyFiles", "coverage_note"],
  "properties": {
    "keyFiles": {
      "type": "array",
      "minItems": 5,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "properties": {
          "path": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "entryPoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["location", "description"],
        "properties": {
          "location": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "appliedWhere"],
        "properties": {
          "name": { "type": "string" },
          "appliedWhere": { "type": "string" }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "internal": { "type": "array", "items": { "type": "string" } },
        "external": { "type": "array", "items": { "type": "string" } }
      }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "coverage_note": { "type": "string" }
  }
}
