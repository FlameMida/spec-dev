{
  "type": "object",
  "required": ["items", "coverage_note"],
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check", "dimension", "tier", "ops", "result", "evidence_ref"],
        "properties": {
          "check": { "type": "string" },
          "dimension": {
            "type": "string",
            "enum": ["unit", "integration", "e2e", "visual", "a11y", "perf-web", "perf-api", "other"]
          },
          "tier": { "type": "string", "enum": ["D", "A", "X"] },
          "requirement_ref": { "type": "string" },
          "ops": { "type": "string" },
          "result": { "type": "string", "enum": ["pass", "warn", "fail", "unverified"] },
          "evidence_ref": { "type": "string" },
          "notes": { "type": "string" },
          "recheck": {
            "type": "object",
            "required": ["status"],
            "properties": {
              "status": { "type": "string", "enum": ["维持", "降级", "翻案"] },
              "evidence_ref": { "type": "string" }
            }
          }
        },
        "if": {
          "type": "object",
          "required": ["result"],
          "properties": { "result": { "enum": ["pass", "fail"] } }
        },
        "then": {
          "type": "object",
          "required": ["evidence_ref"],
          "properties": { "evidence_ref": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "coverage_note": { "type": "string", "minLength": 1 }
  }
}
