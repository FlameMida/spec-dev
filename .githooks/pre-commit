#!/bin/sh
set -eu

# 变量名沿用旧习惯（原 Codex 包同步 hook），语义为跳过插件包校验
if [ "${SKIP_CODEX_PACKAGE_HOOK:-}" = "1" ]; then
  echo "Skipping plugin package pre-commit hook because SKIP_CODEX_PACKAGE_HOOK=1."
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "Validating plugin package with official Codex CLI..."
node scripts/check-plugin.mjs --codex-validate

echo "Validating bundled skills with skill-creator..."
node scripts/validate-skills.mjs

echo "Checking staged diff..."
git diff --cached --check
